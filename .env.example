# Copy this file to .env and fill in your Supabase project credentials.
# Find them at: https://supabase.com/dashboard → your project → Settings → API
#
# Without a .env the app runs in DEMO MODE: login succeeds locally and no
# data is saved — perfect for trying the UI before wiring a backend.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
